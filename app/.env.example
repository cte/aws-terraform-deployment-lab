HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
APP_NAME=Ember Migration Lab
APP_ENVIRONMENT=local
AWS_REGION=us-east-1
AWS_PROFILE=my-test-account
AWS_SDK_LOAD_CONFIG=1
S3_BUCKET=ember-migration-test-assets-n8zad7
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=ember_migration_test
DB_USER=appuser
DB_PASSWORD=appsecret
DB_SSL_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_TLS_ENABLED=false
APP_CONFIG={"queueName":"ember-migration-jobs","uploadPrefix":"uploads","resultPrefix":"results","maxUploadBytes":2097152}
