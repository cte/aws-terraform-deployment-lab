{
  "name": "ember-migration-lab",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "build": "turbo run build",
    "dev": "dotenvx run -fk .env.keys -f .env -- turbo run dev --filter=@ember-migration/app",
    "dev:worker": "dotenvx run -fk .env.keys -f .env -- turbo run dev:worker --filter=@ember-migration/app",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "typecheck": "turbo run typecheck",
    "docker:build:app": "docker build -f packages/app/Dockerfile -t ember-migration-lab .",
    "aws:whoami": "dotenvx run -fk .env.keys -f .env -- aws sts get-caller-identity",
    "terraform:fmt": "pnpm --filter @ember-migration/terraform run fmt",
    "terraform:init": "dotenvx run -fk .env.keys -f .env -- pnpm --filter @ember-migration/terraform run init",
    "terraform:validate": "dotenvx run -fk .env.keys -f .env -- pnpm --filter @ember-migration/terraform run validate",
    "terraform:plan": "dotenvx run -fk .env.keys -f .env -- pnpm --filter @ember-migration/terraform run plan",
    "terraform:apply": "dotenvx run -fk .env.keys -f .env -- pnpm --filter @ember-migration/terraform run apply",
    "terraform:destroy": "dotenvx run -fk .env.keys -f .env -- pnpm --filter @ember-migration/terraform run destroy",
    "env:encrypt": "dotenvx encrypt -fk .env.keys -f .env -k AWS_SECRET_ACCESS_KEY"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.51.1",
    "turbo": "^2.5.8"
  }
}
